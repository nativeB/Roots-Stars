# ─────────────────────────────────────────────────────────────
# Roots & Stars — environment configuration
# Copy to .env and fill in. Never commit a real .env.
# ─────────────────────────────────────────────────────────────

# --- Core ---
# Railway Postgres connection string (reference the Postgres plugin variable on Railway).
DATABASE_URL="postgresql://user:password@localhost:5432/rootsandstars?schema=public"

# Port the single-origin Fastify service listens on (Railway injects PORT in prod).
PORT=8080

# Origin used for building invite links and CORS during local dev (web dev server).
WEB_ORIGIN="http://localhost:5173"

# --- Auth ---
# Secret used to sign device + host JWTs (HS256). Generate: openssl rand -base64 48
API_SECRET="change-me-long-random-string"

# Bootstrap host secret. A per-family hash is stored in Family.hostTokenHash.
# Used by a family creator to claim host (merge/re-parent/delete/seed) rights.
HOST_SECRET="change-me-host-secret"

# --- Cloudflare R2 (S3-compatible photo storage) ---
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET="roots-and-stars"
# R2 S3 endpoint, e.g. https://<accountid>.r2.cloudflarestorage.com
R2_ENDPOINT=""

# --- Web build-time (Vite) ---
# In single-origin production these are same-origin; for local dev point web at the api.
VITE_API_BASE="http://localhost:8080"
